# APP_URL: The URL where this app is hosted (e.g. http://localhost:3000 or your deployed URL).
APP_URL="http://localhost:3000"

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_SERVICE_ACCOUNT_KEY=

# Gmail SMTP (For Contact Form)
GMAIL_APP_PASSWORD=

# Resend API (For Booking Confirmations + Scheduled Reminders)
RESEND_API_KEY=

# Google reCAPTCHA v2
VITE_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Garage Info (used in reminder emails)
GARAGE_ADDRESS=
GARAGE_PHONE=

# Backfill endpoint secret (protects POST /api/reminders/backfill)
BACKFILL_SECRET=

# Google Calendar ID (defaults to jerryservicegarage@gmail.com)
GOOGLE_CALENDAR_ID=
